# Copy this file to .env.local and fill in the values.
# .env.local is git-ignored and must never be committed.
# All keys are read server-side only (never prefixed with NEXT_PUBLIC_).

# Groq API (AI reasoning)
GROQ_API_KEY=

# Spotify Web API (Client Credentials flow)
SPOTIFY_CLIENT_ID=
SPOTIFY_CLIENT_SECRET=

# Optional: ISO 3166-1 alpha-2 market code for Spotify search (e.g. US, IN).
# When unset, Spotify uses its default market for the request.
# SPOTIFY_MARKET=
